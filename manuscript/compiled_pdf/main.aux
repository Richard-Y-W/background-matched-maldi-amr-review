\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Background-matched MALDI-AMR audit.} The audit accepts isolate-level prediction rows from any model. Non-focal AST labels define co-resistance background strata. Within each focal drug and site, valid strata contain at least three resistant and three susceptible isolates. The audit reports raw AUC, matched AUC, background-centered AUC, pairwise within-background accuracy and matched retention. The method is model-agnostic and can be applied retrospectively to any prediction table.\relax }}{4}{figure.caption.4}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:framework}{{1}{4}{\textbf {Background-matched MALDI-AMR audit.} The audit accepts isolate-level prediction rows from any model. Non-focal AST labels define co-resistance background strata. Within each focal drug and site, valid strata contain at least three resistant and three susceptible isolates. The audit reports raw AUC, matched AUC, background-centered AUC, pairwise within-background accuracy and matched retention. The method is model-agnostic and can be applied retrospectively to any prediction table.\relax }{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Four-panel three-score decomposition of MALDI and AST-background signal.} Each panel is one organism-drug pair; within each panel, raw MALDI and background-centered AUCs are computed from CNN/Mega predictions, and the co-resistance-only AUC is computed from non-focal AST labels without spectral inputs. \textit  {E. coli}/ciprofloxacin retains centered signal at interpretable sites, with the clearest MALDI-over-background margin at DRIAMS-D. \textit  {E. coli}/amoxicillin-clavulanic acid shows weak or chance-level centered AUC and a competitive co-resistance-only baseline at external sites. \textit  {S. aureus}/oxacillin shows retained signal at A-2018 and DRIAMS-C; DRIAMS-B has sparse matched support and is not treated as strong evidence. \textit  {K. pneumoniae}/ceftriaxone provides a third-organism sparse/background-sensitive extension in which raw AUC collapses after matching or no valid matched strata remain.\relax }}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:three-way}{{2}{5}{\textbf {Four-panel three-score decomposition of MALDI and AST-background signal.} Each panel is one organism-drug pair; within each panel, raw MALDI and background-centered AUCs are computed from CNN/Mega predictions, and the co-resistance-only AUC is computed from non-focal AST labels without spectral inputs. \textit {E. coli}/ciprofloxacin retains centered signal at interpretable sites, with the clearest MALDI-over-background margin at DRIAMS-D. \textit {E. coli}/amoxicillin-clavulanic acid shows weak or chance-level centered AUC and a competitive co-resistance-only baseline at external sites. \textit {S. aureus}/oxacillin shows retained signal at A-2018 and DRIAMS-C; DRIAMS-B has sparse matched support and is not treated as strong evidence. \textit {K. pneumoniae}/ceftriaxone provides a third-organism sparse/background-sensitive extension in which raw AUC collapses after matching or no valid matched strata remain.\relax }{figure.caption.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Strongest co-resistance edges in the E. coli expanded panel.\relax }}{6}{table.caption.8}\protected@file@percent }
\newlabel{tab:cross-resistance}{{1}{6}{Strongest co-resistance edges in the E. coli expanded panel.\relax }{table.caption.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Primary background-matched audit for the E. coli ciprofloxacin and amoxicillin-clavulanic acid contrast.\relax }}{6}{table.caption.11}\protected@file@percent }
\newlabel{tab:primary-audit}{{2}{6}{Primary background-matched audit for the E. coli ciprofloxacin and amoxicillin-clavulanic acid contrast.\relax }{table.caption.11}{}}
\citation{chambers1997mrsa}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Primary \textit  {E. coli} background-matched contrast.} Circles denote raw external AUC and squares denote background-centered AUC after co-resistance-stratum mean adjustment. Ciprofloxacin retains residual signal at the temporal site and two external sites. Amoxicillin-clavulanic acid weakens at A-2018 and DRIAMS-B and collapses toward chance at DRIAMS-C and DRIAMS-D. Error bars show 95\% bootstrap confidence intervals from 500 replicates.\relax }}{7}{figure.caption.10}\protected@file@percent }
\newlabel{fig:primary-audit}{{3}{7}{\textbf {Primary \textit {E. coli} background-matched contrast.} Circles denote raw external AUC and squares denote background-centered AUC after co-resistance-stratum mean adjustment. Ciprofloxacin retains residual signal at the temporal site and two external sites. Amoxicillin-clavulanic acid weakens at A-2018 and DRIAMS-B and collapses toward chance at DRIAMS-C and DRIAMS-D. Error bars show 95\% bootstrap confidence intervals from 500 replicates.\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {\textit  {S. aureus}/oxacillin second-organism audit.} Oxacillin predictions retained background-centered signal at A-2018 and DRIAMS-C and exceeded the exact-background no-spectrum baseline at both sites. DRIAMS-B is shown for completeness but has only one valid matched stratum. This analysis demonstrates that the audit can identify retained within-background signal beyond \textit  {E. coli}.\relax }}{8}{figure.caption.14}\protected@file@percent }
\newlabel{fig:saureus-oxa}{{4}{8}{\textbf {\textit {S. aureus}/oxacillin second-organism audit.} Oxacillin predictions retained background-centered signal at A-2018 and DRIAMS-C and exceeded the exact-background no-spectrum baseline at both sites. DRIAMS-B is shown for completeness but has only one valid matched stratum. This analysis demonstrates that the audit can identify retained within-background signal beyond \textit {E. coli}.\relax }{figure.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Representative organism-extension audit rows.\relax }}{9}{table.caption.15}\protected@file@percent }
\newlabel{tab:organism-extension}{{3}{9}{Representative organism-extension audit rows.\relax }{table.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Model-family replication of raw-to-background-centered attenuation.\relax }}{9}{table.caption.17}\protected@file@percent }
\newlabel{tab:model-replication}{{4}{9}{Model-family replication of raw-to-background-centered attenuation.\relax }{table.caption.17}{}}
